<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/suryanamaskar/master#"
     xml:base="http://example.org/suryanamaskar/master"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:core="http://example.org/suryanamaskar/core#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/suryanamaskar/master">
        <dc:description>
            Master ontology that integrates core, base Surya Namaskar sequence, and all variants.
        </dc:description>
        <dc:title>Surya Namaskar Master Ontology</dc:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#comment -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#comment"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#label -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#label"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/suryanamaskar/core#belongsToVariant -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#belongsToVariant">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Variant"/>
        <rdfs:label xml:lang="en">belongs to variant</rdfs:label>
        <rdfs:label xml:lang="hi">प्रकार से संबंधित</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasAsana -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasAsana">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:label xml:lang="en">has asana</rdfs:label>
        <rdfs:label xml:lang="hi">आसन है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasBreathingPattern -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasBreathingPattern">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#BreathingPattern"/>
        <rdfs:label xml:lang="en">has breathing pattern</rdfs:label>
        <rdfs:label xml:lang="hi">श्वास पैटर्न है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasCorrection -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasCorrection">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:label xml:lang="en">has correction</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasInversePose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasInversePose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label xml:lang="en">has inverse pose</rdfs:label>
        <rdfs:label xml:lang="hi">विपरीत मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasNextPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasNextPose">
        <owl:inverseOf rdf:resource="http://example.org/suryanamaskar/core#hasPreviousPose"/>
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label xml:lang="en">has next pose</rdfs:label>
        <rdfs:label xml:lang="hi">अगली मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasPossibleError -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPossibleError">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:label xml:lang="en">has possible error</rdfs:label>
        <rdfs:label xml:lang="hi">संभावित त्रुटि है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasPreviousPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#hasPreviousPose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label xml:lang="en">has previous pose</rdfs:label>
        <rdfs:label xml:lang="hi">पिछली मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#involvesBodyPart -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#involvesBodyPart">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
        <rdfs:label xml:lang="en">involves body part</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का अंग शामिल करता है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#repeatsPose -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#repeatsPose">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:label xml:lang="en">repeats pose</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा को दोहराता है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/suryanamaskar/core#sameAsanaAs -->

    <owl:ObjectProperty rdf:about="http://example.org/suryanamaskar/core#sameAsanaAs">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:label xml:lang="en">same asana as</rdfs:label>
        <rdfs:label xml:lang="hi">समान आसन है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/suryanamaskar/core#correctionText -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#correctionText">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">correction text</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार पाठ</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#errorDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#errorDescription">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">error description</rdfs:label>
        <rdfs:label xml:lang="hi">त्रुटि विवरण</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasAlternateName -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasAlternateName">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has alternate name</rdfs:label>
        <rdfs:label xml:lang="hi">वैकल्पिक नाम है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasCYPPage -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasCYPPage">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has CYP page</rdfs:label>
        <rdfs:label xml:lang="hi">सीवाईपी पृष्ठ संख्या</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasChakra -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasChakra">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has chakra</rdfs:label>
        <rdfs:label xml:lang="hi">चक्र है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasLaterality -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasLaterality">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has laterality</rdfs:label>
        <rdfs:label xml:lang="hi">पक्षीयता है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasMantra -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasMantra">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has mantra</rdfs:label>
        <rdfs:label xml:lang="hi">मंत्र है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasSafetyNote -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasSafetyNote">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has safety note</rdfs:label>
        <rdfs:label xml:lang="hi">सुरक्षा टिप्पणी है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#hasSupportType -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#hasSupportType">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has support type</rdfs:label>
        <rdfs:label xml:lang="hi">आधार प्रकार है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/suryanamaskar/core#poseNumber -->

    <owl:DatatypeProperty rdf:about="http://example.org/suryanamaskar/core#poseNumber">
        <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">pose number</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा संख्या</rdfs:label>
    </owl:DatatypeProperty>
    


