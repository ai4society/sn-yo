    <!-- http://example.org/suryanamaskar/core#AshtangaNamaskara -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/core#AshtangaNamaskara">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
        <core:hasAlternateName>Ashtanga namaskara</core:hasAlternateName>
        <core:hasAlternateName>Salute with eight parts or points</core:hasAlternateName>
        <core:hasCYPPage>34</core:hasCYPPage>
