    <!-- http://example.org/suryanamaskar/core#Asana -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#Asana">
        <rdfs:label xml:lang="en">Asana</rdfs:label>
        <rdfs:label xml:lang="hi">आसन</rdfs:label>
        <rdfs:label xml:lang="te">ఆసనం</rdfs:label>
        <rdfs:label xml:lang="bn">আসন</rdfs:label>
        <rdfs:label xml:lang="mr">आसन</rdfs:label>
        <rdfs:label xml:lang="ta">ஆசனம்</rdfs:label>
        <rdfs:label xml:lang="gu">આસન</rdfs:label>
        <rdfs:label xml:lang="ur">آسن</rdfs:label>
        <rdfs:label xml:lang="kn">ಆಸನ</rdfs:label>
        <rdfs:label xml:lang="or">ଆସନ</rdfs:label>
        <rdfs:label xml:lang="ml">ആസനം</rdfs:label>
        <rdfs:label xml:lang="pa">ਆਸਨ</rdfs:label>
        <rdfs:label xml:lang="as">আসন</rdfs:label>
        <rdfs:label xml:lang="mai">आसन</rdfs:label>
        <rdfs:label xml:lang="sat">ᱟᱥᱚᱱᱚ</rdfs:label>
        <rdfs:label xml:lang="mni">ꯑꯥꯁꯅ</rdfs:label>
      </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#BodyPart -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#BodyPart">
        <rdfs:label xml:lang="en">Body Part</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का अंग</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#BreathingPattern -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#BreathingPattern">
        <rdfs:label xml:lang="en">Breathing Pattern</rdfs:label>
        <rdfs:label xml:lang="hi">श्वास पैटर्न</rdfs:label>
        <rdfs:label xml:lang="te">శ్వాస విధానం</rdfs:label>
        <rdfs:label xml:lang="bn">শ্বাসের ধরন</rdfs:label>
        <rdfs:label xml:lang="mr">श्वास पद्धती</rdfs:label>
        <rdfs:label xml:lang="ta">சுவாச முறை</rdfs:label>
        <rdfs:label xml:lang="gu">શ્વાસની પદ્ધતિ</rdfs:label>
        <rdfs:label xml:lang="ur">سانس لینے کا طریقہ</rdfs:label>
        <rdfs:label xml:lang="kn">ಉಸಿರಾಟದ ವಿಧಾನ</rdfs:label>
        <rdfs:label xml:lang="or">ଶ୍ୱାସ ପ୍ରକ୍ରିୟା</rdfs:label>
        <rdfs:label xml:lang="ml">ശ്വാസരീതി</rdfs:label>
        <rdfs:label xml:lang="pa">ਸਾਹ ਲੈਣ ਦਾ ਢੰਗ</rdfs:label>
        <rdfs:label xml:lang="as">শ্বাস-প্ৰশ্বাসৰ ধৰণ</rdfs:label>
        <rdfs:label xml:lang="mai">साँस लेबाक तरीका</rdfs:label>
        <rdfs:label xml:lang="sat">ᱥᱣᱟᱥᱚ ᱯᱚᱤᱴᱚᱨᱱᱚ</rdfs:label>
        <rdfs:label xml:lang="mni">ꯁ꯭ꯋꯥꯁ ꯄꯩꯇꯔ꯭ꯅ</rdfs:label>
      </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#CorrectionInstruction -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#CorrectionInstruction">
        <rdfs:label xml:lang="en">Correction Instruction</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार निर्देश</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#Pose -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#Pose">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/suryanamaskar/core#hasAsana"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Pose</rdfs:label>
        <rdfs:label xml:lang="hi">क्रमिक मुद्रा</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#PoseError -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#PoseError">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/suryanamaskar/core#hasCorrection"/>
                <owl:someValuesFrom rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Pose Error</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा त्रुटि</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#Variant -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#Variant">
        <rdfs:label xml:lang="en">Variant</rdfs:label>
        <rdfs:label xml:lang="hi">संस्करण</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#AlignFrontKneeInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Align the front knee above or near the ankle.</core:correctionText>
        <rdfs:label xml:lang="en">AlignFrontKneeInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">सामने के घुटने को सही स्थिति में रखें</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#AlignPalmsAtChestInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Align the palms at the chest.</core:correctionText>
        <rdfs:label xml:lang="en">AlignPalmsAtChestInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">हथेलियों को छाती के सामने सही रखें</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BalanceWeightEvenlyInstruction">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
        <core:correctionText>Balance weight evenly on both feet.</core:correctionText>
        <rdfs:label xml:lang="en">BalanceWeightEvenlyInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का भार दोनों पैरों पर समान रखें</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/suryanamaskar/base-sn#BaseSN_Pose01 -->

    <owl:NamedIndividual rdf:about="http://example.org/suryanamaskar/base-sn#BaseSN_Pose01">
        <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
        <core:belongsToVariant rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="http://example.org/suryanamaskar/core#Pranamasana"/>
        <core:hasBreathingPattern rdf:resource="http://example.org/suryanamaskar/core#Exhale"/>
        <core:hasNextPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose02"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#CollapsedChestError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#PalmsMisalignedError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#RoundedShouldersError"/>
        <core:hasPossibleError rdf:resource="http://example.org/suryanamaskar/base-sn#UnevenWeightError"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Chest"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Feet"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Neck"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Palms"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Shoulder"/>
        <core:involvesBodyPart rdf:resource="http://example.org/suryanamaskar/core#Spine"/>
        <core:repeatsPose rdf:resource="http://example.org/suryanamaskar/base-sn#BaseSN_Pose12"/>
        <core:hasChakra>Anahata</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
        <core:hasMantra>Om Hraam/Om Mitraya Namah</core:hasMantra>
        <core:hasSafetyNote>Stand upright with balanced weight and avoid locking the knees.</core:hasSafetyNote>
        <core:hasSupportType>StandingTwoFeet</core:hasSupportType>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</core:poseNumber>
