    <!-- http://example.org/suryanamaskar/core#Asana -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#Asana">
        <rdfs:label xml:lang="en">Asana</rdfs:label>
        <rdfs:label xml:lang="hi">आसन</rdfs:label>
        <rdfs:label xml:lang="te">ఆసనం</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#BodyPart -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#BodyPart">
        <rdfs:label xml:lang="en">Body Part</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का अंग</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#BreathingPattern -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#BreathingPattern">
        <rdfs:label xml:lang="en">Breathing Pattern</rdfs:label>
        <rdfs:label xml:lang="hi">श्वास पैटर्न</rdfs:label>
        <rdfs:label xml:lang="te">శ్వాస విధానం</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#CorrectionInstruction -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#CorrectionInstruction">
        <rdfs:label xml:lang="en">Correction Instruction</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार निर्देश</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#Pose -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#Pose">
        <rdfs:label xml:lang="en">Pose</rdfs:label>
        <rdfs:label xml:lang="hi">क्रमिक मुद्रा</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/suryanamaskar/core#PoseError -->

    <owl:Class rdf:about="http://example.org/suryanamaskar/core#PoseError">
