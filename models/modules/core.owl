    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">34</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Uttanamandukasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label xml:lang="en">Uttanamandukasana</rdfs:label>
    <rdfs:label xml:lang="hi">उत्तान मंडूकासन</rdfs:label>
    <rdfs:label xml:lang="te">ఉత్తాన మండూకాసనం</rdfs:label>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stretched-up Frog Pose</hasAlternateName>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Setubandhasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label xml:lang="en">Setubandhasana</rdfs:label>
    <rdfs:label xml:lang="hi">सेतुबंधासन</rdfs:label>
    <rdfs:label xml:lang="te">సేతు బంధాసనం</rdfs:label>
