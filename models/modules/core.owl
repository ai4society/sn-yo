    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Phalakasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Plank pose</hasAlternateName>
    <rdfs:label xml:lang="en">Phalakasana</rdfs:label>
    <rdfs:label xml:lang="hi">फलकासन</rdfs:label>
    <rdfs:label xml:lang="te">ఫలకాసనం</rdfs:label>
    <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#ChaturangaDandasana"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#correctionText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#CorrectionInstruction"/>
