    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hastha uthanasana</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raised arms pose</hasAlternateName>
    <rdfs:label xml:lang="en">Hasta Utthanasana</rdfs:label>
    <rdfs:label xml:lang="hi">हस्त उत्तानासन</rdfs:label>
    <rdfs:label xml:lang="te">హస్త ఉత్తానాసనం</rdfs:label>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">23</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#ChaturangaDandasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chaturanga Dandasan</hasAlternateName>
    <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#Phalakasana"/>
    <rdfs:label xml:lang="en">Chaturanga Dandasana</rdfs:label>
    <rdfs:label xml:lang="hi">चतुरंग दंडासन</rdfs:label>
    <rdfs:label xml:lang="te">చతురంగ దండాసనం</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#AdhoMukhaSvanasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
