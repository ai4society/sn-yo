    <rdfs:label xml:lang="hi">सुधार पाठ</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#hasPossibleError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="http://example.org/suryanamaskar/core#PoseError"/>
