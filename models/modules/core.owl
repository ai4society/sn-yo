>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Spine">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Spine</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Parvatasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mountain pose</hasAlternateName>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parvat-asana</hasAlternateName>
    <sameAsanaAs rdf:resource="http://example.org/suryanamaskar/core#AdhoMukhaSvanasana"/>
    <rdfs:label xml:lang="en">Parvatasana</rdfs:label>
    <rdfs:label xml:lang="hi">पर्वतासन</rdfs:label>
    <rdfs:label xml:lang="te">పర్వతాసనం</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Utkatasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Utkatasana</rdfs:label>
    <rdfs:label xml:lang="hi">उत्कटासन</rdfs:label>
    <rdfs:label xml:lang="te">ఉత్కటాసనం</rdfs:label>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hip stretch pose</hasAlternateName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Vajrasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label xml:lang="en">Vajrasana</rdfs:label>
    <rdfs:label xml:lang="hi">वज्रासन</rdfs:label>
