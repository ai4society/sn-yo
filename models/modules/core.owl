    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">35</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Ardhaustrasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
    <rdfs:label xml:lang="en">Ardhaustrasana</rdfs:label>
    <rdfs:label xml:lang="hi">अर्ध उष्ट्रासन</rdfs:label>
    <rdfs:label xml:lang="te">అర్ధ ఉష్ట్రాసనం</rdfs:label>
    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Half Camel Pose</hasAlternateName>
    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">27</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Uttanapadasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
