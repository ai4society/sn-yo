    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Arms</rdfs:label>
    <rdfs:label xml:lang="hi">बाहें</rdfs:label>
  </rdf:Description>
