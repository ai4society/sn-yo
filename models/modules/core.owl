    <hasCYPPage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">28</hasCYPPage>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Elbow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#BodyPart"/>
