    <rdfs:label xml:lang="hi">संभावित त्रुटि है</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/suryanamaskar/core#Pose"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Hands">
