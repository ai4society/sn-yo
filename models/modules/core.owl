<?xml version="1.0"?>
<rdf:RDF xmlns="https://ai4society.github.io/sn-yo/core#"
     xml:base="https://ai4society.github.io/sn-yo/core"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://ai4society.github.io/sn-yo/core">
        <dc:description>Core ontology for Surya Namaskar variants, containing shared classes, properties, asana individuals, and body-part individuals.</dc:description>
        <dc:title>Surya Namaskar Core Ontology</dc:title>
        <rdfs:label xml:lang="en">Surya Namaskar Core Ontology</rdfs:label>
        <rdfs:label xml:lang="hi">सूर्य नमस्कार कोर ऑन्टोलॉजी</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#comment -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#comment"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#label -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#label"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://ai4society.github.io/sn-yo/core#belongsToVariant -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#belongsToVariant">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Variant"/>
        <rdfs:label xml:lang="en">belongs to variant</rdfs:label>
        <rdfs:label xml:lang="hi">प्रकार से संबंधित</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasAsana -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasAsana">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <rdfs:label xml:lang="en">has asana</rdfs:label>
        <rdfs:label xml:lang="hi">आसन है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasBreathingPattern -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasBreathingPattern">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#BreathingPattern"/>
        <rdfs:label xml:lang="en">has breathing pattern</rdfs:label>
        <rdfs:label xml:lang="hi">श्वास पैटर्न है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasCorrection -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasCorrection">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#PoseError"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#CorrectionInstruction"/>
        <rdfs:label xml:lang="en">has correction</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasInversePose -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasInversePose">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">has inverse pose</rdfs:label>
        <rdfs:label xml:lang="hi">विपरीत मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasNextPose -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasNextPose">
        <owl:inverseOf rdf:resource="https://ai4society.github.io/sn-yo/core#hasPreviousPose"/>
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">has next pose</rdfs:label>
        <rdfs:label xml:lang="hi">अगली मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasPossibleError -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasPossibleError">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#PoseError"/>
        <rdfs:label xml:lang="en">has possible error</rdfs:label>
        <rdfs:label xml:lang="hi">संभावित त्रुटि है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasPreviousPose -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasPreviousPose">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">has previous pose</rdfs:label>
        <rdfs:label xml:lang="hi">पिछली मुद्रा है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#involvesBodyPart -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#involvesBodyPart">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#BodyPart"/>
        <rdfs:label xml:lang="en">involves body part</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का अंग शामिल करता है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#repeatsPose -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#repeatsPose">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">repeats pose</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा को दोहराता है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#sameAsanaAs -->

    <owl:ObjectProperty rdf:about="https://ai4society.github.io/sn-yo/core#sameAsanaAs">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <rdfs:range rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <rdfs:label xml:lang="en">same asana as</rdfs:label>
        <rdfs:label xml:lang="hi">समान आसन है</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://ai4society.github.io/sn-yo/core#correctionText -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#correctionText">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#CorrectionInstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">correction text</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार पाठ</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#errorDescription -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#errorDescription">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#PoseError"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">error description</rdfs:label>
        <rdfs:label xml:lang="hi">त्रुटि विवरण</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasAlternateName -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasAlternateName">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has alternate name</rdfs:label>
        <rdfs:label xml:lang="hi">वैकल्पिक नाम है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasCYPPage -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasCYPPage">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has CYP page</rdfs:label>
        <rdfs:label xml:lang="hi">सीवाईपी पृष्ठ संख्या</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasChakra -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasChakra">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has chakra</rdfs:label>
        <rdfs:label xml:lang="hi">चक्र है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasLaterality -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasLaterality">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has laterality</rdfs:label>
        <rdfs:label xml:lang="hi">पक्षीयता है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasMantra -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasMantra">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has mantra</rdfs:label>
        <rdfs:label xml:lang="hi">मंत्र है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasSafetyNote -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasSafetyNote">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has safety note</rdfs:label>
        <rdfs:label xml:lang="hi">सुरक्षा टिप्पणी है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#hasSupportType -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#hasSupportType">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has support type</rdfs:label>
        <rdfs:label xml:lang="hi">आधार प्रकार है</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://ai4society.github.io/sn-yo/core#poseNumber -->

    <owl:DatatypeProperty rdf:about="https://ai4society.github.io/sn-yo/core#poseNumber">
        <rdfs:domain rdf:resource="https://ai4society.github.io/sn-yo/core#Pose"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">pose number</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा संख्या</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://ai4society.github.io/sn-yo/core#Asana -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#Asana">
        <rdfs:label xml:lang="en">Asana</rdfs:label>
        <rdfs:label xml:lang="hi">आसन</rdfs:label>
        <rdfs:label xml:lang="te">ఆసనం</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#BodyPart -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#BodyPart">
        <rdfs:label xml:lang="en">Body Part</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का अंग</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#BreathingPattern -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#BreathingPattern">
        <rdfs:label xml:lang="en">Breathing Pattern</rdfs:label>
        <rdfs:label xml:lang="hi">श्वास पैटर्न</rdfs:label>
        <rdfs:label xml:lang="te">శ్వాస విధానం</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#CorrectionInstruction -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#CorrectionInstruction">
        <rdfs:label xml:lang="en">Correction Instruction</rdfs:label>
        <rdfs:label xml:lang="hi">सुधार निर्देश</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#Pose -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#Pose">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ai4society.github.io/sn-yo/core#hasAsana"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Pose</rdfs:label>
        <rdfs:label xml:lang="hi">क्रमिक मुद्रा</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#PoseError -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#PoseError">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://ai4society.github.io/sn-yo/core#hasCorrection"/>
                <owl:someValuesFrom rdf:resource="https://ai4society.github.io/sn-yo/core#CorrectionInstruction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Pose Error</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा त्रुटि</rdfs:label>
    </owl:Class>
    


    <!-- https://ai4society.github.io/sn-yo/core#Variant -->

    <owl:Class rdf:about="https://ai4society.github.io/sn-yo/core#Variant">
        <rdfs:label xml:lang="en">Variant</rdfs:label>
        <rdfs:label xml:lang="hi">संस्करण</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://ai4society.github.io/sn-yo/core#AdhoMukhaSvanasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#AdhoMukhaSvanasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <sameAsanaAs rdf:resource="https://ai4society.github.io/sn-yo/core#Parvatasana"/>
        <hasAlternateName>Adho mukha svanasana</hasAlternateName>
        <hasAlternateName>Adhomukha swanasana</hasAlternateName>
        <rdfs:label xml:lang="en">Adho Mukha Svanasana</rdfs:label>
        <rdfs:label xml:lang="hi">अधोमुख श्वानासन</rdfs:label>
        <rdfs:label xml:lang="te">అధో ముఖ శ్వానాసనం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Ankle -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Ankle">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#BodyPart"/>
        <rdfs:label xml:lang="en">Ankle</rdfs:label>
        <rdfs:label xml:lang="hi">टखना</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Ardhachakrasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Ardhachakrasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Half Wheel Pose</hasAlternateName>
        <hasCYPPage>23</hasCYPPage>
        <rdfs:label xml:lang="en">Ardhachakrasana</rdfs:label>
        <rdfs:label xml:lang="hi">अर्ध चक्रासन</rdfs:label>
        <rdfs:label xml:lang="te">అర్ధ చక్రాసనం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Ardhahalasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Ardhahalasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Half Plough Pose</hasAlternateName>
        <hasCYPPage>37</hasCYPPage>
        <rdfs:label xml:lang="en">Ardhahalasana</rdfs:label>
        <rdfs:label xml:lang="hi">अर्ध हलासन</rdfs:label>
        <rdfs:label xml:lang="te">అర్ధ హలాసనం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Ardhaustrasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Ardhaustrasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Half Camel Pose</hasAlternateName>
        <hasCYPPage>27</hasCYPPage>
        <rdfs:label xml:lang="en">Ardhaustrasana</rdfs:label>
        <rdfs:label xml:lang="hi">अर्ध उष्ट्रासन</rdfs:label>
        <rdfs:label xml:lang="te">అర్ధ ఉష్ట్రాసనం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Arms -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Arms">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#BodyPart"/>
        <rdfs:label xml:lang="en">Arms</rdfs:label>
        <rdfs:label xml:lang="hi">बाहें</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#AshtangaNamaskara -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#AshtangaNamaskara">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Ashtanga namaskara</hasAlternateName>
        <hasAlternateName>Salute with eight parts or points</hasAlternateName>
        <hasCYPPage>34</hasCYPPage>
        <rdfs:label xml:lang="en">Ashtanga Namaskara</rdfs:label>
        <rdfs:label xml:lang="hi">अष्टांग नमस्कार</rdfs:label>
        <rdfs:label xml:lang="te">అష్టాంగ నమస్కారం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#AshwaSanchalanasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#AshwaSanchalanasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Ashwa Sanchalan-asana</hasAlternateName>
        <hasAlternateName>Ashwasanchalanasana</hasAlternateName>
        <hasAlternateName>Equestrian pose</hasAlternateName>
        <rdfs:label xml:lang="en">Ashwa Sanchalanasana</rdfs:label>
        <rdfs:label xml:lang="hi">अश्व संचलनासन</rdfs:label>
        <rdfs:label xml:lang="te">అశ్వ సంచలనాసనం</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://ai4society.github.io/sn-yo/core#Bhujangasana -->

    <owl:NamedIndividual rdf:about="https://ai4society.github.io/sn-yo/core#Bhujangasana">
        <rdf:type rdf:resource="https://ai4society.github.io/sn-yo/core#Asana"/>
        <hasAlternateName>Bhujang-asana</hasAlternateName>
        <hasAlternateName>Cobra pose</hasAlternateName>
