    <hasAlternateName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adhomukha swanasana</hasAlternateName>
    <rdfs:label xml:lang="en">Adho Mukha Svanasana</rdfs:label>
    <rdfs:label xml:lang="hi">अधोमुख श्वानासन</rdfs:label>
    <rdfs:label xml:lang="te">అధో ముఖ శ్వానాసనం</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#Padahastasana">
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
