    <rdfs:label xml:lang="en">has asana</rdfs:label>
    <rdfs:label xml:lang="hi">आसन है</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/suryanamaskar/core#HastaUtthanasana">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/suryanamaskar/core#Asana"/>
