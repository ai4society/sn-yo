    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#GentleBackbendInstruction"/>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LengthenSpineInstruction"/>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftUpwardFirstInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#OverextensionError">
