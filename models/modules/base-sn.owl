    <rdfs:label xml:lang="hi">कमर से आगे की ओर झुकें</rdfs:label>
    <core:correctionText>Bend forward from the hips.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#DistributeWeightEvenlyInstruction">
