    <rdfs:label xml:lang="hi">केवल एड़ियों पर भार आने की त्रुटि</rdfs:label>
    <core:errorDescription>Weight is shifted to the heels only.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#DistributeWeightEvenlyInstruction"/>
  </rdf:Description>
