  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#KeepBodyAlignedInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">KeepBodyAlignedInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को सीध में रखें</rdfs:label>
    <core:correctionText>Keep the body aligned in one straight line.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#MaintainHipPositionInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">MaintainHipPositionInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर की स्थिति स्थिर रखें</rdfs:label>
    <core:correctionText>Keep the hips slightly raised.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:imports rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core"/>
    <dc:description>Base SN variant ontology containing Base SN variant individual, pose occurrences, sequence relations, and Base SN-specific correction resources.</dc:description>
    <dc:title>Surya Namaskar Base Sequence Ontology</dc:title>
    <rdfs:label xml:lang="en">Surya Namaskar Base Sequence Ontology</rdfs:label>
    <rdfs:label xml:lang="hi">सूर्य नमस्कार का आधारभूत अनुक्रम ऑन्टोलॉजी</rdfs:label>
  </rdf:Description>
