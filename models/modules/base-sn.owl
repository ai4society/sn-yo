  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#RelaxShouldersInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">RelaxShouldersInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों को ढीला रखें</rdfs:label>
    <core:correctionText>Relax the shoulders.</core:correctionText>
  </rdf:Description>
