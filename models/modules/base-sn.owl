    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">WristOverloadError</rdfs:label>
    <rdfs:label xml:lang="hi">कलाइयों पर अत्यधिक भार की त्रुटि</rdfs:label>
    <core:errorDescription>Too much weight is placed on the wrists.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#DistributeWeightEvenlyInstruction"/>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#PushHipsUpwardInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/core#correctionText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#GentleBackbendInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">GentleBackbendInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">हल्का पीछे झुकें</rdfs:label>
    <core:correctionText>Keep the backbend gentle and controlled.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftChestForwardUpwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LiftChestForwardUpwardInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को आगे और ऊपर उठाएँ</rdfs:label>
    <core:correctionText>Lift the chest forward and upward.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#EngageCoreInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">EngageCoreInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को भीतर से सक्रिय करें</rdfs:label>
    <core:correctionText>Engage the core.</core:correctionText>
  </rdf:Description>
