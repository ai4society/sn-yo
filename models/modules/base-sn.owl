  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/core#poseNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#RaisedShouldersError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">RaisedShouldersError</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों के अधिक उठने की त्रुटि</rdfs:label>
    <core:errorDescription>Shoulders are lifted too much.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RelaxShouldersInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#ExtendBackLegInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">ExtendBackLegInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">पीछे के पैर को पूरी तरह सीधा रखें</rdfs:label>
    <core:correctionText>Extend the back leg fully.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#HipsDroppedFullyError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">HipsDroppedFullyError</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के मध्य भाग को पूरी तरह नीचे गिराने की त्रुटि</rdfs:label>
    <core:errorDescription>Hips are dropped fully to the floor.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#MaintainHipPositionInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose04</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०४</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#AshwaSanchalanasana_LeftLegForward"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Inhale"/>
    <core:hasChakra>Ajna</core:hasChakra>
    <core:hasInversePose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose09"/>
    <core:hasLaterality>Right</core:hasLaterality>
    <core:hasMantra>Om Hraim/Om Bhanave Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose05"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#CollapsedChestError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#KneeBeyondAnkleError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#WeakBackLegError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose03"/>
    <core:hasSafetyNote>Keep the front knee aligned over the ankle and place the back knee gently on the floor.</core:hasSafetyNote>
    <core:hasSupportType>OneLegForward</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Chest"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hands"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Knee"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</core:poseNumber>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose09">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose09</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०९</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#AshwaSanchalanasana_RightLegForward"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Inhale"/>
    <core:hasChakra>Ajna</core:hasChakra>
    <core:hasInversePose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04"/>
    <core:hasLaterality>Left</core:hasLaterality>
    <core:hasMantra>Om Hroom/Om Adityaya Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose10"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#CollapsedChestError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#KneeBeyondAnkleError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#WeakBackLegError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose08"/>
    <core:hasSafetyNote>Step forward smoothly and ensure proper alignment of the front knee over the ankle.</core:hasSafetyNote>
    <core:hasSupportType>OneLegForward</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Chest"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hands"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Knee"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</core:poseNumber>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#UnstableLegsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">UnstableLegsError</rdfs:label>
    <rdfs:label xml:lang="hi">अस्थिर पैरों की त्रुटि</rdfs:label>
    <core:errorDescription>Legs are unstable or poorly aligned.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#StabilizeLegsInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose05">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose05</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०५</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#ChaturangaDandasana"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hold"/>
    <core:hasChakra>Vishuddhi</core:hasChakra>
    <core:hasLaterality>Symmetric</core:hasLaterality>
    <core:hasMantra>Om Hraum/Om Khagaya Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose06"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#ElbowsFlaredError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RaisedHipsError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#SaggingHipsError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04"/>
    <core:hasSafetyNote>Maintain a straight body line from head to heels and avoid sagging or lifting the hips excessively.</core:hasSafetyNote>
    <core:hasSupportType>HandsAndFeet</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Core"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Elbow"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Legs"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Wrist"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</core:poseNumber>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose10">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose10</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा १०</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Padahastasana"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Exhale"/>
    <core:hasChakra>Swadhisthana</core:hasChakra>
    <core:hasLaterality>Symmetric</core:hasLaterality>
    <core:hasMantra>Om Hraim/Om Savitre Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose11"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#ExcessiveKneeBendError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RoundedBackError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose09"/>
    <core:hasSafetyNote>Move into the forward bend with control and avoid overstretching the hamstrings.</core:hasSafetyNote>
    <core:hasSupportType>StandingBentTwoFeet</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Feet"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Knee"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</core:poseNumber>
    <core:repeatsPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose03"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#LengthenSpineInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LengthenSpineInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">रीढ़ को लंबा रखें</rdfs:label>
    <core:correctionText>Lengthen the spine.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#PalmsMisalignedError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">PalmsMisalignedError</rdfs:label>
    <rdfs:label xml:lang="hi">हथेलियों के गलत संरेखण की त्रुटि</rdfs:label>
    <core:errorDescription>Palms are not aligned properly.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#AlignPalmsAtChestInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftChestForwardInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">LiftChestForwardInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">छाती को आगे उठाएँ</rdfs:label>
    <core:correctionText>Lift the chest forward.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#CenterBodyInstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
    <rdfs:label xml:lang="en">CenterBodyInstruction</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर को संतुलित करें</rdfs:label>
    <core:correctionText>Center the body and return to neutral alignment.</core:correctionText>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#CollapsedChestError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">CollapsedChestError</rdfs:label>
    <rdfs:label xml:lang="hi">धंसी हुई छाती की त्रुटि</rdfs:label>
    <core:errorDescription>Chest is collapsed.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftChestForwardInstruction"/>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftChestForwardUpwardInstruction"/>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LiftChestInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#ShoulderTensionError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">ShoulderTensionError</rdfs:label>
    <rdfs:label xml:lang="hi">कंधों में तनाव की त्रुटि</rdfs:label>
    <core:errorDescription>Shoulders are tense.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RelaxShouldersInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#RaisedHipsError">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#PoseError"/>
    <rdfs:label xml:lang="en">RaisedHipsError</rdfs:label>
    <rdfs:label xml:lang="hi">शरीर के मध्य भाग के अधिक उठने की त्रुटि</rdfs:label>
    <core:errorDescription>Hips are raised too high.</core:errorDescription>
    <core:hasCorrection rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#KeepBodyAlignedInstruction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose08">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose08</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा ०८</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Parvatasana"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Exhale"/>
    <core:hasChakra>Vishuddhi</core:hasChakra>
    <core:hasLaterality>Symmetric</core:hasLaterality>
    <core:hasMantra>Om Hreem/Om Marichaye Namah</core:hasMantra>
    <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose09"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RoundedBackError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#UnstableLegsError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#WristOverloadError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose07"/>
    <core:hasSafetyNote>Lengthen the spine and avoid rounding the back; press the heels down gently without forcing.</core:hasSafetyNote>
    <core:hasSupportType>HandsAndFeet</core:hasSupportType>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Ankle"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Arms"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Knee"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Shoulder"/>
    <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
    <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</core:poseNumber>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose12">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
    <rdfs:label xml:lang="en">BaseSN_Pose12</rdfs:label>
    <rdfs:label xml:lang="hi">मुद्रा १२</rdfs:label>
    <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
    <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pranamasana"/>
    <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Exhale"/>
    <core:hasChakra>Anahata</core:hasChakra>
    <core:hasLaterality>Symmetric</core:hasLaterality>
    <core:hasMantra>Om Hrah/Om Bhaskaraya Namah</core:hasMantra>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#CollapsedPostureError"/>
    <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#PoorBalanceError"/>
    <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose11"/>
    <core:hasSafetyNote>Return to a steady standing posture and maintain relaxed, even breathing.</core:hasSafetyNote>
    <core:hasSupportType>StandingTwoFeet</core:hasSupportType>
