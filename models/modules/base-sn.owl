    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#AlignFrontKneeInstruction -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#AlignFrontKneeInstruction">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
        <rdfs:label xml:lang="en">AlignFrontKneeInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">सामने के घुटने को सही स्थिति में रखें</rdfs:label>
        <core:correctionText>Align the front knee above or near the ankle.</core:correctionText>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#AlignPalmsAtChestInstruction -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#AlignPalmsAtChestInstruction">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
        <rdfs:label xml:lang="en">AlignPalmsAtChestInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">हथेलियों को छाती के सामने सही रखें</rdfs:label>
        <core:correctionText>Align the palms at the chest.</core:correctionText>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#BalanceWeightEvenlyInstruction -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BalanceWeightEvenlyInstruction">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#CorrectionInstruction"/>
        <rdfs:label xml:lang="en">BalanceWeightEvenlyInstruction</rdfs:label>
        <rdfs:label xml:lang="hi">शरीर का भार दोनों पैरों पर समान रखें</rdfs:label>
        <core:correctionText>Balance weight evenly on both feet.</core:correctionText>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose01 -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose01">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">BaseSN_Pose01</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा ०१</rdfs:label>
        <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pranamasana"/>
        <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Exhale"/>
        <core:hasChakra>Anahata</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
        <core:hasMantra>Om Hraam/Om Mitraya Namah</core:hasMantra>
        <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose02"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#CollapsedChestError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#PalmsMisalignedError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RoundedShouldersError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#UnevenWeightError"/>
        <core:hasSafetyNote>Stand upright with balanced weight and avoid locking the knees.</core:hasSafetyNote>
        <core:hasSupportType>StandingTwoFeet</core:hasSupportType>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Chest"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Feet"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Neck"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Palms"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Shoulder"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</core:poseNumber>
        <core:repeatsPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose12"/>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose02 -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose02">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">BaseSN_Pose02</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा ०२</rdfs:label>
        <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#HastaUtthanasana"/>
        <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Inhale"/>
        <core:hasChakra>Vishuddhi</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
        <core:hasMantra>Om Hreem/Om Ravaye Namah</core:hasMantra>
        <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose03"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BentArmsError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#LowerBackOverarchingError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#NeckStrainError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RaisedShouldersError"/>
        <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose01"/>
        <core:hasSafetyNote>Lift the chest upward with control and avoid compressing the lower back during the backbend.</core:hasSafetyNote>
        <core:hasSupportType>StandingTwoFeet</core:hasSupportType>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Arms"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Chest"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Neck"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Shoulder"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</core:poseNumber>
        <core:repeatsPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose11"/>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose03 -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose03">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">BaseSN_Pose03</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा ०३</rdfs:label>
        <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Padahastasana"/>
        <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Exhale"/>
        <core:hasChakra>Swadhisthana</core:hasChakra>
        <core:hasLaterality>Symmetric</core:hasLaterality>
        <core:hasMantra>Om Hroom/Om Suryaya Namah</core:hasMantra>
        <core:hasNextPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#ExcessiveKneeBendError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#RoundedBackError"/>
        <core:hasPossibleError rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#WeightOnHeelsOnlyError"/>
        <core:hasPreviousPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose02"/>
        <core:hasSafetyNote>Avoid deep forward bending in case of back pain or tight hamstrings; keep the knees slightly bent and spine long.</core:hasSafetyNote>
        <core:hasSupportType>StandingBentTwoFeet</core:hasSupportType>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Ankle"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Feet"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Hip"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Knee"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Neck"/>
        <core:involvesBodyPart rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Spine"/>
        <core:poseNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</core:poseNumber>
        <core:repeatsPose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose10"/>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04 -->

    <owl:NamedIndividual rdf:about="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose04">
        <rdf:type rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Pose"/>
        <rdfs:label xml:lang="en">BaseSN_Pose04</rdfs:label>
        <rdfs:label xml:lang="hi">मुद्रा ०४</rdfs:label>
        <core:belongsToVariant rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_SivanandaYogaVedantaCentre_UsedatIITBHU"/>
        <core:hasAsana rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#AshwaSanchalanasana"/>
        <core:hasBreathingPattern rdf:resource="https://purl.org/ai4s/yoga/sn-yo/core#Inhale"/>
        <core:hasChakra>Ajna</core:hasChakra>
        <core:hasInversePose rdf:resource="https://purl.org/ai4s/yoga/sn-yo/base-sn#BaseSN_Pose09"/>
        <core:hasLaterality>Right</core:hasLaterality>
        <core:hasMantra>Om Hraim/Om Bhanave Namah</core:hasMantra>
